<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="btnNumber">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">70dp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/btn_number</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="btnLandNumber">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_margin">1dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/btn_number</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="btnOperator" parent="btnNumber">
        <item name="android:background">@drawable/btn_operator</item>
    </style>

    <style name="btnEqual" parent="btnNumber">
        <item name="android:background">@drawable/btn_equal</item>
    </style>

    <style name="btnSci" parent="btnLandNumber">
    </style>
</resources>